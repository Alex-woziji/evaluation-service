# ── Database ──────────────────────────────────────────────────────────────────
DB_BACKEND=local                          # "local" (SQLite) | "azure"
SQLITE_DB_PATH=data/evaluation.db         # SQLite path (local mode)
# AZURE_DB_URL=mock://placeholder        # Azure DB connection string (azure mode)

# ── Azure OpenAI ──────────────────────────────────────────────────────────────
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2025-01-01-preview

# ── LLM Defaults ──────────────────────────────────────────────────────────────
LLM_MODEL=gpt-4.1                         # Model deployment name
LLM_TEMPERATURE=0.0                       # Generation temperature
LLM_MAX_ATTEMPTS=3                        # Max retry attempts (including first)
LLM_BASE_WAIT=2.0                         # Exponential backoff base (seconds)
LLM_MAX_WAIT=10.0                         # Max backoff wait (seconds)
LLM_JITTER=0.5                            # Backoff jitter (seconds)

# ── Application ────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO                            # DEBUG | INFO | WARNING | ERROR
APP_VERSION=2.0.0
BATCH_MAX_CONCURRENCY=5                   # Max concurrent metrics in batch requests
